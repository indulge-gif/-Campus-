.container {
  min-height: 100vh;
  background: #f6f7f9;
}

.header {
  position: relative;
  background: linear-gradient(180deg, #b80f2e 0%, #d82c45 60%, #e95b6a 100%);
  padding: 28rpx;
  border-radius: 0 0 24rpx 24rpx;
}

.header-mask {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.08), transparent 45%),
    radial-gradient(circle at 80% 40%, rgba(255,255,255,0.07), transparent 42%);
  opacity: 0.6;
}

.header-text {
  position: relative;
  z-index: 1;
}

.title {
  display: block;
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  color: rgba(255,255,255,0.92);
  font-size: 24rpx;
}

.list {
  padding: 20rpx 24rpx 30rpx;
}

.card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
}

.cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.meta {
  flex: 1;
  margin-left: 16rpx;
  min-width: 0;
}

.name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #777;
  line-height: 1.4;
}

.hint {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #c3122e;
  flex-shrink: 0;
}
