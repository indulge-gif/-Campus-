<view class="container">
  <view class="header">
    <view class="header-mask"></view>
    <view class="header-text">
      <text class="title">猜你想去</text>
      <text class="subtitle">为你精选几个常用地点</text>
    </view>
  </view>

  <view class="list">
    <view
      wx:for="{{recommendations}}"
      wx:key="id"
      class="card"
      bindtap="toDetail"
      data-id="{{item.id}}"
    >
      <image class="cover" src="{{item.image}}" mode="aspectFill" />
      <view class="meta">
        <text class="name">{{item.name}}</text>
        <text class="desc">{{item.description}}</text>
      </view>
      <text class="hint">查看详情</text>
    </view>
  </view>
</view>
